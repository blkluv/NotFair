{
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs22.x"
    }
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "installCommand": "pnpm install --frozen-lockfile --node-linker=hoisted",
  "buildCommand": "pnpm run vercel-build",
  "outputDirectory": ".next/standalone"
}
